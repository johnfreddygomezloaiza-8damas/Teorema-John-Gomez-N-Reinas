import numpy as np

def generar_tablero_gomez_10x10():
    """Genera la matriz del Tablero de John Gómez de tamaño 10 x 10."""
    n = 10
    tablero = np.zeros((n, n), dtype=int)
    for i in range(n):
        for j in range(n):
            fila_gomez = n - i
            col_gomez = n - j
            tablero[i, j] = n * (fila_gomez - 1) + col_gomez
    return tablero

def auditar_ciclos_gomez_10x10(ciclos_coordenadas):
    """
    Toma una lista con los 4 ciclos (cada uno con 25 coordenadas)
    y verifica el Teorema de John Gómez para N=10.
    """
    tablero = generar_tablero_gomez_10x10()
    K_10 = (10 * (10**2 + 1)) / 2  # Constante base de reinas = 505
    constante_ciclo_teorica = 2.5 * K_10  # 1262.5
    
    print("==================================================================")
    print("📊 AUDITORÍA DEL TEOREMA DE GÓMEZ: 4 CICLOS DEL CABALLO (10x10)")
    print("==================================================================")
    print(f"-> Constante de validación base K_10: {int(K_10)}")
    print(f"-> Suma teórica esperada por ciclo de 25 pasos: {constante_ciclo_teorica}")
    print("------------------------------------------------------------------")
    
    sumas_calculadas = []
    
    for idx, ciclo in enumerate(ciclos_coordenadas):
        # Extraer los valores numéricos que pisa el caballo en el Tablero de Gómez
        valores_casillas = [tablero[r, c] for r, c in ciclo]
        suma_ciclo = sum(valores_casillas)
        sumas_calculadas.append(suma_ciclo)
        
        print(f"🔹 Ciclo {idx + 1} (25 pasos): Suma Real = {suma_ciclo}")
        # Verificar el desvío simétrico de ±0.5 respecto a 1262.5
        if suma_ciclo in [1262, 1263]:
            print(f"   [OK] Complementariedad perfecta detectada ({suma_ciclo} ≈ 1262.5)")
            
    print("------------------------------------------------------------------")
    # Demostración del acoplamiento por parejas completas
    suma_total_tablero = sum(sumas_calculadas)
    print(f"▶️ Suma combinada de los 4 ciclos (100 casillas): {suma_total_tablero}")
    print(f"▶️ Suma de comprobación universal de Gauss (1 al 100): 5050")
    
    if suma_total_tablero == 5050:
        print("\n🏆 ¡TEOREMA CONFIRMADO EN 10x10! Los ciclos se acoplan en perfecto equilibrio.")
        return True
    return False

